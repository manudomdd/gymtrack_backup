<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_purple"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bienvenido, Coach" android:textSize="24sp" android:textStyle="bold" android:textColor="@color/magenta"/>
        <Space android:layout_width="wrap_content" android:layout_height="24dp"/>

        <!-- Fila 1 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardBackgroundColor="@color/input_field_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="22sp"/>
                    <Space android:layout_width="wrap_content" android:layout_height="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clientes Totales" android:textSize="12sp" android:textColor="@color/white_54"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <Space android:layout_width="16dp" android:layout_height="wrap_content"/>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardBackgroundColor="@color/input_field_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✅" android:textSize="22sp"/>
                    <Space android:layout_width="wrap_content" android:layout_height="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Activos Hoy" android:textSize="12sp" android:textColor="@color/white_54"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <Space android:layout_width="wrap_content" android:layout_height="16dp"/>

        <!-- Fila 2 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardBackgroundColor="@color/input_field_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏋" android:textSize="22sp"/>
                    <Space android:layout_width="wrap_content" android:layout_height="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entrenamientos" android:textSize="12sp" android:textColor="@color/white_54"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="127" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <Space android:layout_width="16dp" android:layout_height="wrap_content"/>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardBackgroundColor="@color/input_field_bg" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="22sp"/>
                    <Space android:layout_width="wrap_content" android:layout_height="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esta Semana" android:textSize="12sp" android:textColor="@color/white_54"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="34" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <Space android:layout_width="wrap_content" android:layout_height="32dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Accesos Rápidos" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/magenta"/>
        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>

        <Button android:id="@+id/btn_see_clients" style="@style/Widget.GymTrack.Button.Purple" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:text="Ver Todos mis Clientes" />
        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>
        <Button android:id="@+id/btn_create_plan" style="@style/Widget.GymTrack.Button.Outline" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:text="Crear Nuevo Plan de Entrenamiento" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Card de visualización de una sola serie de entrenamiento.
    Muestra: Grupo Muscular (subtítulo), Ejercicio (título principal),
    y los chips de datos: Serie N | Peso | Reps | RIR.
    El botón Eliminar se mantiene para futura implementación.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/input_field_bg"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Grupo Muscular (subtítulo) -->
        <TextView
            android:id="@+id/tv_muscle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pecho"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="@color/white_54"
            android:letterSpacing="0.1" />

        <Space android:layout_width="wrap_content" android:layout_height="4dp"/>

        <!-- Nombre del Ejercicio (título) -->
        <TextView
            android:id="@+id/tv_exercise_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Press de Banca"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/magenta" />

        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>

        <!-- Fila de métricas: Serie | Peso | Reps | RIR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Serie N -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Serie"
                    android:textSize="12sp"
                    android:textColor="@color/white_54"/>
                <TextView
                    android:id="@+id/tv_sets"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Peso -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peso (kg)"
                    android:textSize="12sp"
                    android:textColor="@color/white_54"/>
                <TextView
                    android:id="@+id/tv_peso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Repeticiones -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reps"
                    android:textSize="12sp"
                    android:textColor="@color/white_54"/>
                <TextView
                    android:id="@+id/tv_reps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- RIR -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RIR"
                    android:textSize="12sp"
                    android:textColor="@color/white_54"/>
                <TextView
                    android:id="@+id/tv_rir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Comentario (oculto si vacío) -->
        <TextView
            android:id="@+id/tv_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/white_54"
            android:fontStyle="italic"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <!-- Botón eliminar (esquina inferior derecha) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">
            <ImageButton
                android:id="@+id/btn_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_edit"
                android:background="@android:color/transparent"
                android:tint="@color/magenta"
                android:padding="8dp"
                android:visibility="gone" />
            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_delete"
                android:background="@android:color/transparent"
                android:tint="@color/error_red"
                android:padding="8dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="25dp"
        android:paddingRight="25dp"
        android:paddingTop="70dp"
        android:paddingBottom="30dp"
        android:gravity="center_horizontal">

        <!-- Título CREAR / CUENTA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CREAR"
            android:textSize="50sp"
            android:textStyle="bold"
            android:textColor="@color/magenta"
            android:fontFamily="sans-serif-black"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CUENTA"
            android:textSize="55sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginTop="-8dp" />

        <Space android:layout_width="wrap_content" android:layout_height="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Únete a GymTrack y empieza a mejorar"
            android:textSize="14sp"
            android:textColor="@color/white_54"
            android:gravity="center" />

        <Space android:layout_width="wrap_content" android:layout_height="40dp" />

        <!-- Card de Registro -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/input_field_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp">

                <!-- Nombre -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_nombre"
                    style="@style/Widget.GymTrack.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre Completo">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_nombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:inputType="textPersonName" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space android:layout_width="wrap_content" android:layout_height="15dp" />

                <!-- Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/Widget.GymTrack.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="example@email.com">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space android:layout_width="wrap_content" android:layout_height="15dp" />

                <!-- Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_password"
                    style="@style/Widget.GymTrack.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña (min 6 caracteres)"
                    app:passwordToggleEnabled="true">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:inputType="textPassword" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space android:layout_width="wrap_content" android:layout_height="25dp" />

                <!-- Rol de Usuario -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Qué tipo de usuario eres?"
                    android:textSize="14sp"
                    android:textColor="@color/white_54"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rg_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <RadioButton
                        android:id="@+id/rb_cliente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cliente"
                        android:textColor="@color/white"
                        android:buttonTint="@color/magenta"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb_entrenador"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Entrenador"
                        android:textColor="@color/white"
                        android:buttonTint="@color/magenta" />
                </RadioGroup>

                <Space android:layout_width="wrap_content" android:layout_height="25dp" />

                <!-- Código de Entrenador (Solo para Clientes) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_trainer_code"
                    style="@style/Widget.GymTrack.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Código de Entrenador (Opcional)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_trainer_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textAllCaps="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#334D0073" />

                <Space android:layout_width="wrap_content" android:layout_height="15dp" />

                <!-- Peso y Altura en fila -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_peso"
                        style="@style/Widget.GymTrack.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Peso (kg)">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_peso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Space android:layout_width="15dp" android:layout_height="wrap_content" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_altura"
                        style="@style/Widget.GymTrack.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Altura (cm)">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_altura"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <Space android:layout_width="wrap_content" android:layout_height="30dp" />

                <!-- NEAT Slider -->
                <TextView
                    android:id="@+id/tv_neat_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NIVEL DE ACTIVIDAD FISICA DIARIA: Moderado"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_neat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="5"
                    android:stepSize="1"
                    android:value="3"
                    app:thumbColor="@color/magenta"
                    app:trackColorActive="@color/magenta"
                    app:trackColorInactive="#334D0073" />

                <Space android:layout_width="wrap_content" android:layout_height="30dp" />

                <!-- Botón Crear Cuenta -->
                <Button
                    android:id="@+id/btn_register"
                    style="@style/Widget.GymTrack.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Crear Cuenta" />

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:indeterminateTint="@color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Space android:layout_width="wrap_content" android:layout_height="20dp" />

        <!-- Volver al Login -->
        <Button
            android:id="@+id/btn_go_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta? Inicia Sesión"
            android:background="@android:color/transparent"
            android:textColor="@color/white_54"
            android:textStyle="bold" />

        <Space android:layout_width="wrap_content" android:layout_height="30dp" />

    </LinearLayout>
</ScrollView>

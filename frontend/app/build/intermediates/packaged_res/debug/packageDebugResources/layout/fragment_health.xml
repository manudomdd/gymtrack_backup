<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_purple"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PARÁMETROS DE SALUD"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-black" />

    <Space android:layout_width="wrap_content" android:layout_height="30dp" />

    <!-- Card Pasos -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/input_field_bg"
        app:cardCornerRadius="15dp"
        android:layout_marginBottom="20dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">
            
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_directions"
                app:tint="@color/magenta" />
            
            <Space android:layout_width="20dp" android:layout_height="wrap_content" />
            
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pasos hoy"
                    android:textColor="@color/white_54"
                    android:textSize="12sp" />
                
                <TextView
                    android:id="@+id/tv_steps_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Card Sueño -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/input_field_bg"
        app:cardCornerRadius="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro de Sueño"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space android:layout_width="wrap_content" android:layout_height="20dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.GymTrack.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Horas dormidas">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_sleep_hours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="wrap_content" android:layout_height="15dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calidad del sueño (1-10)"
                android:textColor="@color/white_54"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/spinner_sleep_quality"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input_field"
                android:theme="@style/Theme.GymTrack" />

            <Space android:layout_width="wrap_content" android:layout_height="25dp" />

            <Button
                android:id="@+id/btn_save_sleep"
                style="@style/Widget.GymTrack.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Registro" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>

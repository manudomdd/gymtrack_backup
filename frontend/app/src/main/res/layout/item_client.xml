<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/input_field_bg"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Avatar + Nombre/Email -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <LinearLayout android:id="@+id/iv_avatar" android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_avatar_purple" android:gravity="center">
                <TextView android:id="@+id/tv_avatar_letter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/magenta"/>
            </LinearLayout>
            <Space android:layout_width="12dp" android:layout_height="wrap_content"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tv_client_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Juan García" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white"/>
                <TextView android:id="@+id/tv_client_email" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="juan@gmail.com" android:textSize="12sp" android:textColor="@color/white_54"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>

        <!-- Rutina + Último entrenamiento -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@drawable/bg_badge_purple" android:padding="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rutina" android:textSize="12sp" android:textColor="@color/white_54"/>
                <TextView android:id="@+id/tv_rutina" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Push/Pull/Legs" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="end">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Último Entreno" android:textSize="12sp" android:textColor="@color/white_54"/>
                <TextView android:id="@+id/tv_last_workout" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ayer" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>

        <!-- Peso + Altura + Estado -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Peso" android:textSize="12sp" android:textColor="@color/white_54"/>
                <TextView android:id="@+id/tv_peso" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="82.5 kg" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Altura" android:textSize="12sp" android:textColor="@color/white_54"/>
                <TextView android:id="@+id/tv_altura" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="178 cm" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Edad" android:textSize="12sp" android:textColor="@color/white_54"/>
                <TextView android:id="@+id/tv_edad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="25 años" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/white"/>
            </LinearLayout>
        </LinearLayout>

        <Space android:layout_width="wrap_content" android:layout_height="12dp"/>

        <!-- Botones de acción -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn_diary" style="@style/Widget.GymTrack.Button.Outline" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Diario" android:textSize="12sp" android:padding="4dp"/>
            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btn_metrics" style="@style/Widget.GymTrack.Button.Outline" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Métricas" android:textSize="12sp" android:padding="4dp"/>
            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btn_biomarkers" style="@style/Widget.GymTrack.Button.Outline" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Biomarcadores" android:textSize="12sp" android:padding="4dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

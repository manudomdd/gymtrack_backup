    <style name="Theme.GymTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/magenta</item>
        <item name="colorPrimaryVariant">@color/primary_purple</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_purple</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/deep_purple</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/deep_purple</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white_54</item>
        
        <item name="colorControlActivated">@color/magenta</item>
        <item name="colorControlNormal">@color/primary_purple</item>
        
        <item name="alertDialogTheme">@style/Theme.GymTrack.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.GymTrack.Dialog</item>
    </style>
    <style name="Theme.GymTrack.AppBar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/input_field_bg</item>
        <item name="titleTextColor">@color/magenta</item>
        <item name="navigationIconTint">@color/magenta</item>
    </style>
    <style name="Theme.GymTrack.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/input_field_bg</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white_54</item>
        <item name="colorPrimary">@color/magenta</item>
        <item name="colorAccent">@color/magenta</item>
    </style>
    <style name="Widget.GymTrack.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/magenta</item>
        <item name="android:textColor">@color/magenta</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="Widget.GymTrack.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/magenta</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">30dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    <style name="Widget.GymTrack.Button.Purple" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_purple</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>
    <style name="Widget.GymTrack.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/deep_purple</item>
        <item name="boxStrokeColor">@color/magenta</item>
        <item name="hintTextColor">@color/white_54</item>
        <item name="android:textColorHint">@color/white_54</item>
        <item name="startIconTint">@color/primary_purple</item>
        <item name="boxCornerRadiusBottomEnd">15dp</item>
        <item name="boxCornerRadiusBottomStart">15dp</item>
        <item name="boxCornerRadiusTopEnd">15dp</item>
        <item name="boxCornerRadiusTopStart">15dp</item>
    </style>
